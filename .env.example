# Supabase — optional, only needed for the online leaderboard.
# Without this the game works fully, just no global rankings.
#
# 1. Go to https://supabase.com → create a project
# 2. Settings → API → copy Project URL and anon/public key
# 3. Rename this file to .env and fill in your values
# 4. Add the same vars in Vercel → Project Settings → Environment Variables

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
