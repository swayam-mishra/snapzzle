# Firebase — optional, only needed for the online leaderboard.
# Without it the game works fully, just no global rankings.
#
# 1. Go to https://console.firebase.google.com → create a project
# 2. Add a web app → copy the config values below
# 3. Enable Firestore Database (start in test mode)
# 4. Rename this file to .env and fill in your values
# 5. Add the same vars in Vercel → Project Settings → Environment Variables

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
